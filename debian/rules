#!/usr/bin/make -f
# debian/rules

%:
	dh $@ --buildsystem=cargo

override_dh_auto_test:
	# Skip tests during package build; they require specific test data files
	# that are not available in the Debian build environment.
	true

override_dh_strip:
	# The Cargo release profile (see Cargo.toml [profile.release]) already
	# strips symbols via strip = "symbols". Do not strip again to avoid
	# corrupting the binary.
	true
